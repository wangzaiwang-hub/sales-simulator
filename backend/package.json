{
  "name": "sales-simulator-backend",
  "version": "1.0.0",
  "description": "销售模拟器后端API",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "copy:deployment-assets": "node scripts/copyDeploymentAssets.mjs",
    "build": "cp -r ../resource ./resource && npm run copy:deployment-assets && prisma generate && tsc",
    "start": "node dist/index.js",
    "sync:secondme-keys": "tsx src/scripts/syncSecondMeAvatarKeys.ts",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:push": "prisma db push"
  },
  "dependencies": {
    "express": "^4.18.2",
    "cors": "^2.8.5",
    "dotenv": "^16.4.0",
    "@prisma/client": "^5.9.0",
    "jsonwebtoken": "^9.0.2",
    "axios": "^1.6.0",
    "zod": "^3.22.0",
    "bcrypt": "^5.1.1"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/cors": "^2.8.17",
    "@types/node": "^20.11.0",
    "@types/jsonwebtoken": "^9.0.5",
    "@types/bcrypt": "^5.0.2",
    "typescript": "^5.3.3",
    "tsx": "^4.7.0",
    "prisma": "^5.9.0"
  }
}
