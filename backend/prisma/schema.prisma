generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// 用户表
model User {
  id            String    @id @default(uuid())
  secondmeId    String    @unique
  username      String
  email         String?
  avatar        String?
  profession    String?
  interests     Json?
  personaSummary String?
  npcBehavior   String?   @default("wander")
  secondmeProfile Json?
  isNpcVisible  Boolean   @default(true)
  secondmeAccessToken String?
  secondmeApiKey String?
  secondmeTokenScope String?
  secondmeTokenExpiresAt DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  
  gameProgress  GameProgress?
  shop          Shop?
  transactions  Transaction[]
}

// 游戏进度
model GameProgress {
  id            String    @id @default(uuid())
  userId        String    @unique
  user          User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  level         Int       @default(1)
  experience    Int       @default(0)
  gold          Int       @default(1000)
  
  positionX     Float     @default(100)
  positionY     Float     @default(100)
  currentMap    String    @default("main")
  
  characterAppearance Json?  // 角色外观配置
  
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

// 商店
model Shop {
  id            String    @id @default(uuid())
  userId        String    @unique
  user          User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  name          String
  level         Int       @default(1)
  reputation    Int       @default(0)
  
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  
  inventory     Inventory[]
}

// 商品定义
model Product {
  id            String    @id @default(uuid())
  name          String
  description   String?
  category      String
  basePrice     Int
  icon          String?
  
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  
  inventory     Inventory[]
  transactions  TransactionItem[]
}

// 库存
model Inventory {
  id            String    @id @default(uuid())
  shopId        String
  shop          Shop      @relation(fields: [shopId], references: [id], onDelete: Cascade)
  productId     String
  product       Product   @relation(fields: [productId], references: [id])
  
  quantity      Int       @default(0)
  buyPrice      Int
  sellPrice     Int
  
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  
  @@unique([shopId, productId])
}

// 交易记录
model Transaction {
  id            String    @id @default(uuid())
  userId        String
  user          User      @relation(fields: [userId], references: [id])
  
  type          String    // "buy" | "sell"
  totalAmount   Int
  npcName       String?
  
  createdAt     DateTime  @default(now())
  
  items         TransactionItem[]
}

// 交易项目
model TransactionItem {
  id            String    @id @default(uuid())
  transactionId String
  transaction   Transaction @relation(fields: [transactionId], references: [id], onDelete: Cascade)
  productId     String
  product       Product   @relation(fields: [productId], references: [id])
  
  quantity      Int
  price         Int
  
  createdAt     DateTime  @default(now())
}
